rules_version = '2';

// Social Connect — Cloud Storage security rules.
service firebase.storage {
  match /b/{bucket}/o {

    // Profile images: publicly readable; only the owner can write their file.
    match /profile_images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && fileName == request.auth.uid + '.jpg';
    }

    // Post images: publicly readable; any signed-in user can upload.
    match /post_images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
