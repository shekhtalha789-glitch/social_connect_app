rules_version = '2';

// Social Connect — Firestore security rules.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // User profiles: anyone signed in can read; only the owner can write.
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // Posts: readable by any signed-in user.
    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid;
      // Any signed-in user may update (like/unlike + comment counters).
      allow update: if signedIn();
      // Only the author may delete their post.
      allow delete: if signedIn()
        && resource.data.authorId == request.auth.uid;

      // Comments under a post.
      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid;
        // Only the comment's author may delete it.
        allow delete: if signedIn()
          && resource.data.authorId == request.auth.uid;
      }
    }
  }
}
